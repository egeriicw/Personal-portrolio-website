---
const navLinks = [
  { label: 'About', href: '/about' },
  { label: 'Projects', href: '/projects' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-gray-100 bg-surface/80 backdrop-blur-sm sticky top-0 z-10">
  <nav class="container flex items-center justify-between h-16">
    <a href="/" class="font-semibold text-gray-900 hover:text-gray-600 text-sm tracking-tight">
      Your Name
    </a>
    <ul class="flex items-center gap-6">
      {navLinks.map(({ label, href }) => {
        const isActive = currentPath === href || currentPath.startsWith(href + '/');
        return (
          <li>
            <a
              href={href}
              class:list={[
                'text-sm transition-colors',
                isActive
                  ? 'text-gray-900 font-medium'
                  : 'text-gray-500 hover:text-gray-900',
              ]}
            >
              {label}
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
</header>
