---
interface Props {
  title: string;
  date: Date;
  description: string;
  slug: string;
}

const { title, date, description, slug } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group border-b border-gray-100 py-6 last:border-b-0">
  <time class="text-xs text-gray-400 font-mono">{formattedDate}</time>
  <a href={`/blog/${slug}`} class="block mt-1 mb-2">
    <h3 class="text-lg font-semibold text-gray-900 group-hover:text-gray-600 transition-colors">
      {title}
    </h3>
  </a>
  <p class="text-sm text-gray-500 leading-relaxed">{description}</p>
  <a href={`/blog/${slug}`} class="inline-block mt-3 text-xs text-gray-500 hover:text-gray-900 transition-colors">
    Read more &rarr;
  </a>
</article>
