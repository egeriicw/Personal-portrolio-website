---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Your Name — Portfolio" description="Personal portfolio of Your Name.">
  <Hero />

  {featuredProjects.length > 0 && (
    <section class="section border-t border-gray-100">
      <div class="container">
        <div class="flex items-center justify-between mb-10">
          <h2 class="text-2xl font-semibold text-gray-900">Featured Projects</h2>
          <a href="/projects" class="text-sm text-gray-500 hover:text-gray-900 transition-colors">
            View all &rarr;
          </a>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {featuredProjects.map((project) => (
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              tags={project.data.tags}
              slug={project.slug}
              liveUrl={project.data.liveUrl}
              repoUrl={project.data.repoUrl}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section border-t border-gray-100">
    <div class="container max-w-2xl">
      <h2 class="text-2xl font-semibold text-gray-900 mb-4">About Me</h2>
      <p class="text-gray-500 leading-relaxed mb-6">
        A short paragraph about yourself — your background, what you're working on, and what
        you care about. Keep it to two or three sentences so visitors get the gist quickly.
      </p>
      <a href="/about" class="btn-secondary">Read more about me</a>
    </div>
  </section>
</BaseLayout>
